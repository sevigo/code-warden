# config.yaml.example
#
# Copy this file to config.yaml and customize for your environment.
# Environment variables can override any value using underscore notation:
#   server.port -> SERVER_PORT
#   ai.gemini_api_key -> AI_GEMINI_API_KEY

# ============================================================================
# Server Configuration
# ============================================================================
server:
  port: "8080"
  max_workers: 5
  # FastAPI server URL for external embedding service (optional)
  fastapi_server_url: "http://127.0.0.1:8000"
  # Shared secret for service-to-service auth
  shared_secret: ""
  # UI theme: "dark" or "light"
  theme: "dark"

# ============================================================================
# GitHub App Configuration (required for server mode)
# ============================================================================
github:
  # GitHub App ID (required for server)
  app_id: 0
  # Webhook secret for validating GitHub webhooks
  webhook_secret: ""
  # Path to the GitHub App private key file
  private_key_path: "keys/code-warden-app.private-key.pem"
  # Personal access token (for CLI commands like preload)
  token: "ghp_YOUR_PERSONAL_ACCESS_TOKEN_HERE"

# ============================================================================
# AI Configuration
# ============================================================================
ai:
  # LLM provider for code generation: "ollama" or "gemini"
  llm_provider: "ollama"
  # Embedder provider: "ollama" or "gemini"
  embedder_provider: "ollama"
  
  # Ollama settings (when using ollama provider)
  # Point to your LOCAL Ollama instance (not Docker)
  ollama_host: "http://localhost:11434"
  
  # Gemini settings (when using gemini provider)
  # Set via environment variable AI_GEMINI_API_KEY for security
  gemini_api_key: ""

  # Reranker model for 2-stage retrieval (always uses Ollama, regardless of llm_provider).
  # Use a code-optimized model for best quality - it understands code semantics better.
  # Recommended: "qwen2.5-coder:7b" (best quality) or "qwen2.5-coder:1.5b" (faster, smaller)
  # Alternatives: "gemma3:1b" (lightweight), "codellama:7b"
  reranker_model: "qwen2.5-coder:7b"

  # Enable 2-stage retrieval (reranker improves context relevance, adds ~0.5s latency).
  # Set to false if you want maximum speed and can tolerate slightly less precise context.
  enable_reranking: true

  # Fast Model (The "Validator" - Gemma, Qwen-Coder-1.5b)
  # Used for high-frequency tasks: generating search query variations, validating snippet relevance.
  # Needs to be very fast and cheap.
  fast_model: "gemma3:1b"

  # Model names
  # Generator Model (The "Main Driver" - Kimi)
  generator_model: "kimi-k2.5:cloud"
  
  # Consensus Models (The "Trio" - Kimi, DeepSeek, Gemini)
  # Used for both "Consensus Code Review" and "Architectural Comparison"
  comparison_models: 
    - "kimi-k2.5:cloud"
    - "deepseek-v3.1:671b-cloud"
    - "gemini-3-pro-preview:latest"
    
  # Consensus Quorum (0.0 to 1.0)
  # Percentage of models that must finish before synthesis begins. 
  # Set to 1.0 to wait for EVERY model (safest but slowest).
  # Set to 0.66 to proceed when 2/3 of models finished (balanced).
  consensus_quorum: 0.66
    
  # Paths for Architectural Comparison (used by `prescan`)
  # Default is "." (root only). Add specific high-level directories for deeper analysis.
  comparison_paths:
    - "."
    - "internal/core"
    - "internal/llm"

  embedder_model: "nomic-embed-text"
  embedder_task_description: "search_document"

  # Thinking/Reasoning Mode - for models that support it (DeepSeek-R1, Qwen 3, Kimi-K2.5, etc.)
  # Enables transparent decision-making in code reviews. Models show their reasoning process.
  # Note: Some models like qwen3-coder-next do NOT support thinking.
  enable_thinking: false
  # Thinking effort level: "low", "medium", "high" (for supported models)
  thinking_effort: "medium"

  # Model Memory Management - keep models loaded for faster subsequent responses
  # Examples: "5m" (5 minutes), "10m", "1h", "0" (unload immediately)
  model_keep_alive: "10m"

  # HTTP Client Overrides
  # Timeout for waiting for the first byte of an LLM response (headers).
  # Increase this if you see "timeout awaiting response headers" errors
  # when using heavy cloud models via Ollama proxy.
  # default: "180s" (3 minutes)
  http_response_header_timeout: "15m"

  # Overall HTTP request timeout (including body transfer).
  # This is a safety net for very long-running requests.
  # Set to "0" or omit to disable (rely only on response_header_timeout).
  # default: "0" (disabled - recommended for most cases)
  # http_request_timeout: "0"

  # Overall HTTP request timeout (including body transfer).
  # This is a safety net for very long-running requests.
  # Set to "0" or omit to disable (rely only on response_header_timeout).
  # default: "0" (disabled - recommended for most cases)
  # http_request_timeout: "0"

  # Overall HTTP request timeout (including body transfer).
  # Set to 0 or omit to disable (rely only on response_header_timeout).
  # This is a safety net for very long-running requests.
  # default: "600s" (10 minutes)
  # http_request_timeout: "30m"

  # Context Assembly
  # Maximum tokens for RAG context (retrieved code snippets, definitions, etc.)
  # This is NOT the full prompt - it's just the retrieved context portion.
  # Recommendation based on model context window:
  #   - 8K context models: 4000-6000
  #   - 32K context models: 12000-20000
  #   - 128K context models: 16000-50000 (16000 is a conservative default)
  #   - 256K+ context models: 50000-100000
  # Note: Leave room for system prompt (~1K), diff (~4K), and response (~8K-16K)
  context_token_budget: 16000

  # Maximum number of architectural summaries (directories) to load during context generation.
  # If a repository has more directories than this limit, only the most relevant will be fetched.
  # Increase this for massive monorepos where you need complete coverage.
  # default: 1000
  max_context_summaries: 1000

# ============================================================================
# Agent Configuration (Autonomous Issue Implementation)
# ============================================================================
# The agent system implements GitHub issues autonomously using AI agents.
# It connects to an agent provider (OpenCode, Claude, etc.) via MCP tools
# to search code, review changes, and create pull requests.
#
# Architecture:
#   code-warden ──► MCP Server (port 8081) ◄──► Agent Provider
#                        │                           │
#                        ▼                           ▼
#                   RAG/Qdrant              HTTP API (mode: server)
#                   Code Index                     or
#                                                 CLI (mode: cli)
#
agent:
  # Enable the agent system for /implement comments on GitHub issues
  enabled: true

  # Agent provider: "opencode", "goose", "claude", etc.
  # Currently only "opencode" is fully supported.
  provider: "opencode"

  # Connection mode: "server" (HTTP API) or "cli" (subprocess)
  # - "server": Connects to agent provider via HTTP API (recommended)
  #   - Uses goframe/agent SDK for communication
  #   - Requires opencode_url to be set
  #   - Better error handling and structured responses
  # - "cli": Spawns agent binary as subprocess (legacy)
  #   - Requires agent binary in PATH
  #   - Uses CLI output parsing (AGENT_RESULT sentinels)
  mode: "server"

  # OpenCode server URL (required when mode is "server")
  # The OpenCode server must be running and accessible.
  # For Docker: http://opencode:3000
  # For local: http://localhost:3000
  opencode_url: "http://localhost:3000"

  # Model to use for the agent (provider-specific format)
  # Examples:
  #   - "ollama/qwen2.5-coder" (Ollama)
  #   - "anthropic/claude-3-5-sonnet" (Anthropic)
  #   - "openai/gpt-4" (OpenAI)
  model: "ollama/qwen2.5-coder"

  # Maximum review iterations before stopping
  # The agent will iterate: implement → review → fix up to this many times
  max_iterations: 3

  # Maximum concurrent agent sessions (prevents resource exhaustion)
  max_concurrent_sessions: 3

  # MCP server address (where agent connects to use code-warden tools)
  # Tools available: search_code, get_arch_context, get_symbol, get_structure,
  #                  review_code, push_branch, create_pull_request
  mcp_addr: "127.0.0.1:8081"

  # Timeout for individual MCP tool calls (e.g., code_review)
  # Some operations like code review can take time with large diffs
  mcp_timeout: "5m"

  # Maximum time for an agent session
  # Includes all iterations, reviews, and PR creation
  timeout: "1h"

  # Working directory for agent workspaces
  # Each session gets an isolated workspace: <working_dir>/<session_id>/
  # Must be an absolute path
  # IMPORTANT: This directory must be mounted into the OpenCode Docker container
  # at /agent-workspaces (see docker-compose.yml)
  working_dir: "/tmp/code-warden-agents"

# ============================================================================
# Storage Configuration
# ============================================================================
storage:
  # Qdrant vector database host (gRPC port)
  qdrant_host: "localhost:6334"
  # Local path for cloned repositories
  repo_path: "./data/repos"

# ============================================================================
# Database Configuration
# ============================================================================
database:
  driver: "postgres"
  host: "localhost"
  port: 5432
  database: "codewarden"
  username: "warden"
  # Set via environment variable DATABASE_PASSWORD for security
  password: "secret"
  ssl_mode: "disable"
  max_open_conns: 25
  max_idle_conns: 5
  conn_max_lifetime: "5m"
  conn_max_idle_time: "5m"

# ============================================================================
# Logging Configuration
# ============================================================================
logging:
  # Log level: "debug", "info", "warn", "error"
  level: "info"
  # Log format: "text" or "json"
  format: "text"
  # Output: "stdout", "stderr", or "file"
  output: "stdout"

# ============================================================================
# Feature Flags
# ============================================================================
features:
  # Enable binary quantization for faster vector search
  enable_binary_quantization: true
  # Enable graph-based code analysis
  enable_graph_analysis: true
